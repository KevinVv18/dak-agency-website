# Example environment variables for DAK Agency Website
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_NOTIFICATION=your_template_notification_id
VITE_EMAILJS_TEMPLATE_AUTOREPLY=your_template_autoreply_id
VITE_API_URL=https://admin.dakagency.net
